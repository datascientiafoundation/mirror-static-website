	<item>
		<title>The DataScientia Event 2026: Strengthening Global Collaborations – South Africa Edition</title>
		<link>/events/the-datascientia-event-2026-community-projects-and-education/</link>
		
		<dc:creator><![CDATA[Ali Hamza]]></dc:creator>
